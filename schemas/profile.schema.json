{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sitcon.camp/2026/profile.schema.json",
  "title": "SITCON Camp 2026 Public Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["github", "displayName", "tagline", "interests", "faction"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "github": {
      "type": "string",
      "description": "GitHub username used for avatar and profile link.",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 24
    },
    "tagline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "interests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 12
      }
    },
    "faction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "browser", "editor"],
      "properties": {
        "os": {
          "type": "string",
          "enum": ["windows", "macos", "linux", "chromeos", "ipad", "other"]
        },
        "browser": {
          "type": "string",
          "enum": ["chrome", "firefox", "edge", "safari", "brave", "arc", "other"]
        },
        "editor": {
          "type": "string",
          "enum": ["vscode", "visualstudio", "jetbrains", "vim", "emacs", "zed", "sublime", "other"]
        }
      }
    }
  }
}
